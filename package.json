{
  "name": "ovogogogo",
  "version": "0.1.0",
  "description": "Lightweight OpenAI-compatible autonomous code execution engine",
  "type": "module",
  "main": "dist/bin/ovogogogo.js",
  "bin": {
    "ovolv999": "./dist/bin/ovogogogo.js"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/bin/ovogogogo.js',0o755)\"",
    "start": "node dist/bin/ovogogogo.js",
    "dev": "tsx bin/ovogogogo.ts",
    "lint": "eslint src/ bin/ tests/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ bin/ --fix",
    "format": "prettier --write src/ bin/",
    "format:check": "prettier --check src/ bin/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:integration": "vitest run tests/gap tests/phase tests/eval",
    "eval:deterministic": "vitest run tests/eval/",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && npm run lint && vitest run"
  },
  "dependencies": {
    "@types/react": "^18.3.31",
    "glob": "^11.0.0",
    "ink": "^5.2.1",
    "openai": "^4.77.0",
    "react": "^18.3.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
